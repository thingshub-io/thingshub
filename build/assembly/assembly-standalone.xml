<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
	<id>standalone</id>
	<formats>
		<format>tar.gz</format>
	</formats>

	<includeBaseDirectory>true</includeBaseDirectory>
	<files>
		<file>
			<source>${project.build.directory}/${project.parent.artifactId}-${project.parent.version}.jar</source>
			<outputDirectory>lib</outputDirectory>
		</file>
		<file>
			<source>${project.build.directory}/banner.txt</source>
			<outputDirectory>etc</outputDirectory>
		</file>
		<file>
			<source>${project.basedir}/../thingshub-starter/src/main/resources/config.yaml</source>
			<outputDirectory>etc</outputDirectory>
		</file>
		<file>
			<source>${project.basedir}/../thingshub-starter/src/main/resources/logback.xml</source>
			<outputDirectory>etc</outputDirectory>
		</file>
	</files>
	<fileSets>
		<fileSet>
			<lineEnding>unix</lineEnding>
			<fileMode>0755</fileMode>
			<includes>
				<include>bin/*.sh</include>
			</includes>
		</fileSet>
		<fileSet>
			<includes>
				<include>etc/**</include>
			</includes>
		</fileSet>
		<fileSet>
			<includes>
				<include>doc/**</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${project.build.directory}</directory>
			<outputDirectory>work</outputDirectory>
			<excludes>
				<exclude>**/*</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<directory>${project.build.directory}</directory>
			<outputDirectory>log</outputDirectory>
			<excludes>
				<exclude>**/*</exclude>
			</excludes>
		</fileSet>
	</fileSets>
	<dependencySets>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<excludes>
				<exclude>${project.groupId}:thingshub-commons</exclude>
				<exclude>${project.groupId}:thingshub-core</exclude>
				<exclude>${project.groupId}:thingshub-transport-mqtt</exclude>
				<exclude>${project.groupId}:thingshub-transport-http</exclude>
				<exclude>${project.groupId}:thingshub-transport-tcp</exclude>
				<exclude>${project.groupId}:thingshub-transport-gb28181</exclude>
				<exclude>${project.groupId}:thingshub-dashboard-server</exclude>
				<exclude>${project.groupId}:thingshub-starter</exclude>
			</excludes>
		</dependencySet>
	</dependencySets>
</assembly>