        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="保存昊易车位锁物模型属性列表" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
	&quot;productCode&quot;: &quot;HY-001&quot;,&#xd;
	&quot;properties&quot;: [&#xd;
		{&#xd;
			&quot;name&quot;: &quot;车辆状态&quot;,&#xd;
			&quot;identifier&quot;: &quot;carState&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;enum&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;0&quot;:&quot;无车&quot;,&#xd;
					&quot;1&quot;:&quot;有车&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;车位上是否有车&quot;	&#xd;
		},&#xd;
		{&#xd;
			&quot;name&quot;: &quot;水位状态&quot;,&#xd;
			&quot;identifier&quot;: &quot;waterState&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;enum&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;0&quot;:&quot;正常&quot;,&#xd;
					&quot;1&quot;:&quot;水位过高&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;水位状态&quot;	&#xd;
		},&#xd;
		{&#xd;
			&quot;name&quot;: &quot;锁状态&quot;,&#xd;
			&quot;identifier&quot;: &quot;lockState&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;enum&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;0&quot;:&quot;升到位&quot;,&#xd;
					&quot;1&quot;:&quot;降到位&quot;,&#xd;
					&quot;2&quot;:&quot;降锁故障&quot;,&#xd;
					&quot;3&quot;:&quot;升锁故障&quot;,&#xd;
					&quot;4&quot;:&quot;其它故障&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;锁状态&quot;	&#xd;
		},&#xd;
		{&#xd;
			&quot;name&quot;: &quot;锁角度&quot;,&#xd;
			&quot;identifier&quot;: &quot;lockAngle&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;int&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;min&quot;:&quot;-1&quot;,&#xd;
					&quot;max&quot;:&quot;90&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;锁当前的角度。-1表示未知&quot;&#xd;
		},&#xd;
		{&#xd;
			&quot;name&quot;: &quot;降锁源&quot;,&#xd;
			&quot;identifier&quot;: &quot;lockSource&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;enum&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;0&quot;:&quot;指令&quot;,&#xd;
					&quot;1&quot;:&quot;进水&quot;,&#xd;
					&quot;2&quot;:&quot;断网&quot;,&#xd;
					&quot;3&quot;:&quot;无车&quot;,&#xd;
					&quot;4&quot;:&quot;低电量&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;降锁原因&quot;&#xd;
		},&#xd;
		{&#xd;
			&quot;name&quot;: &quot;电池电压&quot;,&#xd;
			&quot;identifier&quot;: &quot;batV&quot;,	&#xd;
			&quot;dataType&quot;: {&#xd;
				&quot;type&quot;:&quot;int&quot;,&#xd;
				&quot;specs&quot;:{&#xd;
					&quot;unit&quot;:&quot;mv&quot;,&#xd;
					&quot;unitName&quot;:&quot;毫伏&quot;&#xd;
				}&#xd;
			},&#xd;
			&quot;accessMode&quot;: &quot;r&quot;,&#xd;
			&quot;desc&quot;: &quot;电池电压&quot;&#xd;
		},&#xd;
